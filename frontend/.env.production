# 前端生产环境配置（前后端分离部署）
# Cloudflare Pages / Vercel 等平台会优先使用平台里配置的 VITE_* 环境变量。
# 本文件只作为本地生产构建的默认值。

# 后端 API 地址
VITE_API_BASE=https://twice.kdns.fr/api
VITE_STATIC_BASE=https://twice.kdns.fr/static

VITE_PLAYER_BASE=/player

# 视频背景（Cloudflare R2 CDN）
VITE_HOME_BG_VIDEO=https://cdn.274747.xyz/me-you-bg.mp4
VITE_SITE_BG_VIDEO=https://cdn.274747.xyz/me-you-bg.mp4
