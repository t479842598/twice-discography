# 前端生产环境配置（前后端分离部署）
# Vite 构建时会自动读取此文件，VITE_* 变量会被打包进产物。
# 此文件提交到 Git，确保 Cloudflare Pages / Vercel 等平台构建时配置一定生效。

# 后端 API 地址（Render）
VITE_API_BASE=https://twice-discography.onrender.com/api
VITE_STATIC_BASE=https://twice-discography.onrender.com/static

VITE_PLAYER_BASE=/player

# 视频背景（Cloudflare R2 CDN）
VITE_HOME_BG_VIDEO=https://cdn.274747.xyz/me-you-bg.mp4
VITE_SITE_BG_VIDEO=https://cdn.274747.xyz/me-you-bg.mp4
