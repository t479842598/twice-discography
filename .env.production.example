# ===== Backend (Production) =====
# Copy this file to .env.production and fill in actual secrets.
# The server loads .env first, then .env.production (overrides).

BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
NODE_ENV=production

# Database — 使用本地数据库（内置）
DATABASE_PATH=./data/twice.db

# 单体部署模式
SERVE_FRONTEND=true

# CORS / Frontend origins (comma-separated)
FRONTEND_ORIGIN=https://twice.479842598.xyz
CORS_ORIGIN=

STATIC_PREFIX=/static

# MusicSquare providers
JOOX_TOKEN=

# Cloudflare R2 music cache
MUSIC_R2_CACHE_ENABLED=true
MUSIC_R2_CACHE_MISS_MODE=background
MUSIC_R2_MIN_AUDIO_BYTES=16384
MUSIC_R2_MAX_BYTES=9126805504
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=twice-music-assets
R2_PUBLIC_BASE_URL=https://cdn2.479842598.xyz

# ===== Frontend build =====
VITE_API_BASE=/api
VITE_STATIC_BASE=/static
VITE_PLAYER_BASE=/player
VITE_HOME_BG_VIDEO=/media/me-you-bg.mp4
VITE_SITE_BG_VIDEO=/media/me-you-bg.mp4

# B站凭证加密密钥
BILI_CREDENTIAL_ENCRYPTION_KEY=
