# ===== Backend =====
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_PATH=./data/twice.db

# 部署模式：true=单体部署（后端提供前端静态文件），false=前后端分离
SERVE_FRONTEND=true

# CORS - 开发环境
CORS_ORIGIN=http://localhost:5173

# 前后端分离时的前端域名（多个用逗号分隔）
# 生产环境示例：FRONTEND_ORIGIN=https://twice.pages.dev,https://twice.yourdomain.com
FRONTEND_ORIGIN=

# Static assets prefix
STATIC_PREFIX=/static

# MusicSquare-compatible providers
# JOOX is disabled when this is empty.
JOOX_TOKEN=

# ===== Frontend =====
# 开发环境：指向本地后端
VITE_API_BASE=http://localhost:3000/api
VITE_STATIC_BASE=http://localhost:3000/static

# 生产环境（前后端分离）示例：
# VITE_API_BASE=https://your-backend.onrender.com/api
# VITE_STATIC_BASE=https://your-backend.onrender.com/static

# 生产环境（单体部署）示例：
# VITE_API_BASE=/api
# VITE_STATIC_BASE=/static

VITE_PLAYER_BASE=/player
# Optional homepage video background. Defaults to /media/me-you-bg.mp4.
# Use a local public file or a CDN URL that you have rights to distribute.
VITE_HOME_BG_VIDEO=/media/me-you-bg.mp4
# Optional global site video background. Defaults to VITE_HOME_BG_VIDEO.
VITE_SITE_BG_VIDEO=/media/me-you-bg.mp4
