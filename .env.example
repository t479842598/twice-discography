# ===== Backend =====
BACKEND_PORT=3000
BACKEND_HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_PATH=./data/twice.db

# CORS
CORS_ORIGIN=http://localhost:5173

# Static assets prefix
